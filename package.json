{
  "name": "next-electron-app",
  "version": "0.1.0",
  "private": true,
  "description": "A Next.js app with Electron integration",
  "author": "Your Name",
  "build": {
    "appId": "com.yourname.appname",
    "icon": "settings/icon",
    "directories": {
      "output": "dist"
    }
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "build:static": "next build",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development ELECTRON_DISABLE_SECURITY_WARNINGS=1 electron .\"",
    "electron:build": "npm run build:static && cross-env NODE_ENV=production electron .",
    "dist": "npm run build:static && electron-builder",
    "electron": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && cross-env ELECTRON_DISABLE_SECURITY_WARNINGS=1 electron .\""
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron-is-dev": "^3.0.1",
    "exceljs": "^4.4.0",
    "input-otp": "^1.4.2",
    "jsbarcode": "^3.12.3",
    "lucide-react": "^0.554.0",
    "motion": "^12.36.0",
    "next": "16.0.3",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.71.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "wait-on": "^9.0.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "electron": "^40.1.0",
    "electron-builder": "^26.7.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.3",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "main": "electron/main.js"
}
